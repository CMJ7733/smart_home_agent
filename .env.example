# 复制为 .env 并填入真实值，.env 已在 .gitignore 中排除

# ==== LLM Provider: "ollama" | "api" ====
LLM_PROVIDER=ollama

# ==== Ollama (Local) ====
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL_NAME=qwen3.5:2b
EMBEDDING_MODEL_NAME=nomic-embed-text-v2-moe

# ==== OpenAI-compatible API (set LLM_PROVIDER=api to activate) ====
# DeepSeek:    API_BASE_URL=https://api.deepseek.com/v1       API_MODEL_NAME=deepseek-chat
# Qwen:        API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  API_MODEL_NAME=qwen-turbo
# SiliconFlow: API_BASE_URL=https://api.siliconflow.cn/v1     API_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# MiniMax:     API_BASE_URL=https://api.minimaxi.com/v1       API_MODEL_NAME=minimax-m2.7
API_BASE_URL=https://api.minimaxi.com/v1
API_KEY=
API_MODEL_NAME=minimax-m2.7

# ==== Embedding Provider: "ollama" | "api" (独立于 LLM_PROVIDER) ====
# 推荐：chat 用 API，embedding 继续用本地 Ollama（免费）
EMBED_PROVIDER=ollama
# 如果 embedding 也用 API（需要支持 /embeddings 接口的服务商，如 SiliconFlow）：
# EMBED_PROVIDER=api
# EMBED_MODEL_NAME=BAAI/bge-m3
# EMBED_API_BASE_URL=https://api.siliconflow.cn/v1

# ==== Redis (Phase 2) ====
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# ==== LangSmith (Phase 3) ====
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=smart-home-agent
LANGCHAIN_TRACING_V2=false

# ==== Milvus (Phase 2) ====
MILVUS_URI=http://localhost:19530
